# Azure AD App Registration Client ID
# Create an App Registration in Azure AD with:
#   - Platform: Single Page Application (SPA)
#   - Redirect URIs: http://localhost:5173 (dev) + your production URL
#   - API Permissions: Dynamics CRM > user_impersonation (delegated)
VITE_MSAL_CLIENT_ID=your-azure-ad-app-client-id

# Azure AD Tenant ID (use 'common' for multi-tenant)
VITE_MSAL_TENANT_ID=common

# Default Dataverse org URL (can be overridden at runtime)
VITE_DEFAULT_ORG_URL=https://decat.crm.dynamics.com
